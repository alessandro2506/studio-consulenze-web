---
import { it } from '../content/it';

const navLinks = [
  { href: '/', label: it.nav.home },
  { href: '/chi-siamo', label: it.nav.chiSiamo },
  { href: '/servizi', label: it.nav.servizi },
  { href: '/team', label: it.nav.team },
  { href: '/faq', label: it.nav.faq },
  { href: '/contatti', label: it.nav.contatti },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-gray-200 bg-white/95 backdrop-blur-sm"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo testuale -->
      <a href="/" class="flex flex-col leading-tight" aria-label="Home">
        <span
          class="text-lg font-semibold tracking-tight"
          style="font-family: var(--font-heading); color: var(--color-primary);"
        >
          {it.studio.shortName}
        </span>
        <span class="text-xs tracking-widest uppercase" style="color: var(--color-accent);">
          Consulenza Tributaria
        </span>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-7" aria-label="Navigazione principale">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class={[
                  'text-sm font-medium tracking-wide transition-colors duration-150',
                  isActive
                    ? 'border-b-2 pb-0.5'
                    : 'hover:opacity-70',
                ].join(' ')}
                style={
                  isActive
                    ? `color: var(--color-primary); border-color: var(--color-accent);`
                    : `color: var(--color-muted);`
                }
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            );
          })
        }
      </nav>

      <!-- CTA desktop -->
      <a href="/contatti" class="hidden lg:inline-block btn-primary text-sm">
        Prenota una Consulenza
      </a>

      <!-- Hamburger mobile -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 rounded"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-open"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          style="color: var(--color-primary);"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
        <svg
          id="icon-close"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          style="color: var(--color-primary);"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-gray-100 bg-white"
    role="dialog"
    aria-label="Menu mobile"
  >
    <nav class="flex flex-col px-6 py-4 gap-1">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === '/' ? currentPath === '/' : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class="py-2.5 text-sm font-medium border-b border-gray-50 last:border-0"
              style={
                isActive
                  ? `color: var(--color-accent);`
                  : `color: var(--color-primary);`
              }
            >
              {label}
            </a>
          );
        })
      }
      <a href="/contatti" class="btn-primary mt-4 text-center text-sm">
        Prenota una Consulenza
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
