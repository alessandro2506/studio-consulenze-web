---
export interface Props {
  icon: string;
  title: string;
  description: string;
  details?: string[];
  href?: string;
  variant?: 'default' | 'compact';
}

const {
  icon,
  title,
  description,
  details = [],
  href,
  variant = 'default',
} = Astro.props;
---

<article
  class={`card group flex flex-col h-full ${variant === 'compact' ? 'p-6' : 'p-8'}`}
>
  <!-- Icon -->
  <div
    class="w-12 h-12 flex items-center justify-center text-2xl mb-5 shrink-0"
    style="background-color: var(--color-bg-alt);"
    aria-hidden="true"
  >
    {icon}
  </div>

  <!-- Title -->
  <h3
    class="text-xl font-semibold mb-3 group-hover:opacity-80 transition-opacity"
    style="font-family: var(--font-heading); color: var(--color-primary);"
  >
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm leading-relaxed flex-1" style="color: var(--color-muted);">
    {description}
  </p>

  <!-- Detail list (only on full variant) -->
  {
    variant === 'default' && details.length > 0 && (
      <ul class="mt-5 space-y-1.5">
        {details.map((d) => (
          <li class="flex items-start gap-2 text-sm" style="color: var(--color-muted);">
            <span
              class="mt-0.5 w-4 h-4 shrink-0 flex items-center justify-center"
              style="color: var(--color-accent);"
            >
              ✓
            </span>
            {d}
          </li>
        ))}
      </ul>
    )
  }

  <!-- Link -->
  {
    href && (
      <a
        href={href}
        class="mt-6 text-sm font-medium inline-flex items-center gap-1.5 transition-opacity hover:opacity-70"
        style="color: var(--color-accent);"
      >
        Scopri di più
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </a>
    )
  }
</article>
