---
import { it } from '../content/it';
---

<footer style="background-color: var(--color-primary); color: white;">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Studio info -->
      <div class="lg:col-span-2">
        <div class="mb-4">
          <p
            class="text-xl font-semibold"
            style="font-family: var(--font-heading);"
          >
            {it.studio.name}
          </p>
          <p class="text-sm mt-0.5" style="color: var(--color-accent);">
            Consulenza Tributaria · Palermo
          </p>
        </div>
        <p class="text-sm leading-relaxed opacity-80 max-w-xs">
          {it.footer.tagline}
        </p>
        <p class="mt-4 text-sm opacity-70">
          P.IVA {it.studio.piva}
        </p>
      </div>

      <!-- Navigazione -->
      <div>
        <h3
          class="text-xs font-semibold tracking-widest uppercase mb-4 opacity-60"
        >
          Navigazione
        </h3>
        <ul class="space-y-2 text-sm opacity-80">
          <li><a href="/" class="hover:opacity-100 transition-opacity">Home</a></li>
          <li><a href="/chi-siamo" class="hover:opacity-100 transition-opacity">Chi Siamo</a></li>
          <li><a href="/servizi" class="hover:opacity-100 transition-opacity">Servizi</a></li>
          <li><a href="/team" class="hover:opacity-100 transition-opacity">Il Team</a></li>
          <li><a href="/faq" class="hover:opacity-100 transition-opacity">FAQ</a></li>
          <li><a href="/contatti" class="hover:opacity-100 transition-opacity">Contatti</a></li>
        </ul>
      </div>

      <!-- Contatti -->
      <div>
        <h3
          class="text-xs font-semibold tracking-widest uppercase mb-4 opacity-60"
        >
          Contatti
        </h3>
        <address class="not-italic text-sm opacity-80 space-y-2">
          <p>
            <svg class="inline w-4 h-4 mr-1.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {it.studio.address}
          </p>
          <p>
            <a
              href={`tel:${it.studio.phone.replace(/\s/g, '')}`}
              class="hover:opacity-100 transition-opacity"
            >
              <svg class="inline w-4 h-4 mr-1.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {it.studio.phone}
            </a>
          </p>
          <p>
            <a
              href={`mailto:${it.studio.email}`}
              class="hover:opacity-100 transition-opacity"
            >
              <svg class="inline w-4 h-4 mr-1.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {it.studio.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs opacity-60"
    >
      <p>{it.footer.copyright}</p>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:opacity-100 transition-opacity">
          {it.footer.privacy}
        </a>
        <a href="/note-legali" class="hover:opacity-100 transition-opacity">
          {it.footer.legal}
        </a>
      </div>
    </div>
  </div>
</footer>
