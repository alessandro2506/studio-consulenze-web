---
import { it } from '../content/it';

export interface Props {
  title?: string;
  subtitle?: string;
  cta?: string;
  ctaHref?: string;
  ctaSecondary?: string;
  ctaSecondaryHref?: string;
  minHeight?: string;
}

const {
  title = it.hero.title,
  subtitle = it.hero.subtitle,
  cta = it.hero.cta,
  ctaHref = '/servizi',
  ctaSecondary = it.hero.ctaSecondary,
  ctaSecondaryHref = '/contatti',
  minHeight = 'min-h-[88vh]',
} = Astro.props;
---

<section
  class={`relative flex items-center ${minHeight} overflow-hidden`}
  style="background-color: var(--color-primary);"
>
  <!-- Background pattern overlay -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"
  >
  </div>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, rgba(27,58,92,0.97) 0%, rgba(18,39,64,0.92) 60%, rgba(27,58,92,0.85) 100%);"
  >
  </div>

  <!-- Accent line left -->
  <div
    class="absolute left-0 top-1/4 w-1 h-24 opacity-60"
    style="background-color: var(--color-accent);"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8 py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12">
    <div>
      <!-- Eyebrow -->
      <p
        class="text-xs font-semibold tracking-[0.2em] uppercase mb-6"
        style="color: var(--color-accent);"
      >
        Studio di Consulenza Tributaria · Palermo
      </p>

      <!-- Title -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-white"
        style="font-family: var(--font-heading);"
      >
        {title}
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl leading-relaxed mb-10 opacity-80 text-white max-w-2xl">
        {subtitle.replace('TODO:foundedYear', it.studio.foundedYear)}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={ctaHref} class="btn-primary text-center text-sm font-medium">
          {cta}
        </a>
        <a href={ctaSecondaryHref} class="btn-outline text-center text-sm font-medium">
          {ctaSecondary}
        </a>
      </div>

      <!-- Stats strip -->
      <div
        class="mt-16 pt-10 border-t border-white/10 grid grid-cols-3 gap-6 max-w-md"
      >
        <div>
          <p class="text-3xl font-bold" style="font-family: var(--font-heading); color: var(--color-accent);">
            {it.studio.foundedYear}+
          </p>
          <p class="text-xs opacity-60 text-white mt-1">Anno Fondazione</p>
        </div>
        <div>
          <p class="text-3xl font-bold" style="font-family: var(--font-heading); color: var(--color-accent);">
            6
          </p>
          <p class="text-xs opacity-60 text-white mt-1">Aree di Servizio</p>
        </div>
        <div>
          <p class="text-3xl font-bold" style="font-family: var(--font-heading); color: var(--color-accent);">
            PA
          </p>
          <p class="text-xs opacity-60 text-white mt-1">Palermo, Sicilia</p>
        </div>
      </div>
    </div>

    <!-- Collage immagini — solo desktop -->
    <div class="hidden lg:block relative h-[500px]" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=400&q=80"
        alt=""
        class="absolute rounded-lg shadow-2xl object-cover border-2 border-white/20 w-44 h-60"
        style="top:0; left:2rem; transform:rotate(-6deg);"
        loading="eager"
      />
      <img
        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80"
        alt=""
        class="absolute rounded-lg shadow-2xl object-cover border-2 border-white/20 w-48 h-64 z-10"
        style="top:2rem; left:10rem; transform:rotate(4deg);"
        loading="eager"
      />
      <img
        src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=400&q=80"
        alt=""
        class="absolute rounded-lg shadow-2xl object-cover border-2 border-white/20 w-44 h-56 z-20"
        style="top:8rem; left:4rem; transform:rotate(-3deg);"
        loading="eager"
      />
      <img
        src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=400&q=80"
        alt=""
        class="absolute rounded-lg shadow-2xl object-cover border-2 border-white/20 w-40 h-52"
        style="top:6rem; left:13rem; transform:rotate(7deg); z-index:5;"
        loading="eager"
      />
    </div>

    </div>
  </div>
</section>
