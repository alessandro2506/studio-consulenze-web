---
import { it } from '../content/it';

// TODO: Sostituire '#' con l'URL endpoint Formspree reale: https://formspree.io/f/XXXXXXXX
const FORMSPREE_ACTION = '#';
---

<form
  id="contact-form"
  action={FORMSPREE_ACTION}
  method="POST"
  class="space-y-5"
  novalidate
>
  <!-- Nome e Email -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        {it.contatti.form.namePlaceholder} <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder={it.contatti.form.namePlaceholder}
        required
        class="w-full px-4 py-3 text-sm border border-gray-200 focus:outline-none focus:ring-2 transition-shadow"
        style="focus-ring-color: var(--color-accent);"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        {it.contatti.form.emailPlaceholder} <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder={it.contatti.form.emailPlaceholder}
        required
        class="w-full px-4 py-3 text-sm border border-gray-200 focus:outline-none focus:ring-2 transition-shadow"
      />
    </div>
  </div>

  <!-- Telefono e Oggetto -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="phone" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        {it.contatti.form.phonePlaceholder}
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder={it.contatti.form.phonePlaceholder}
        class="w-full px-4 py-3 text-sm border border-gray-200 focus:outline-none focus:ring-2 transition-shadow"
      />
    </div>
    <div>
      <label for="subject" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        {it.contatti.form.subjectPlaceholder} <span class="text-red-500">*</span>
      </label>
      <select
        id="subject"
        name="subject"
        required
        class="w-full px-4 py-3 text-sm border border-gray-200 focus:outline-none focus:ring-2 transition-shadow bg-white"
        style="color: var(--color-text);"
      >
        <option value="" disabled selected>Seleziona un argomento...</option>
        <option value="consulenza-fiscale">Consulenza Fiscale</option>
        <option value="diritto-tributario">Diritto Tributario</option>
        <option value="contabilita">Contabilità e Bilancio</option>
        <option value="dichiarazioni">Dichiarazioni dei Redditi</option>
        <option value="assistenza-imprese">Assistenza Imprese</option>
        <option value="altro">Altro</option>
      </select>
    </div>
  </div>

  <!-- Messaggio -->
  <div>
    <label for="message" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
      {it.contatti.form.messagePlaceholder} <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      placeholder={it.contatti.form.messagePlaceholder}
      required
      class="w-full px-4 py-3 text-sm border border-gray-200 focus:outline-none focus:ring-2 transition-shadow resize-none"
    ></textarea>
  </div>

  <!-- Privacy -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-0.5 w-4 h-4 shrink-0 accent-current"
      style="accent-color: var(--color-primary);"
    />
    <label for="privacy" class="text-xs leading-relaxed" style="color: var(--color-muted);">
      {it.contatti.form.privacy}
    </label>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    class="btn-primary w-full sm:w-auto text-center"
  >
    {it.contatti.form.submit}
  </button>

  <!-- Success / Error messages (JS) -->
  <div id="form-success" class="hidden p-4 text-sm text-green-800 bg-green-50 border border-green-200">
    Messaggio inviato con successo. Ti risponderemo al più presto.
  </div>
  <div id="form-error" class="hidden p-4 text-sm text-red-800 bg-red-50 border border-red-200">
    Si è verificato un errore. Riprova o contattaci direttamente per telefono.
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    const action = form.getAttribute('action');
    if (!action || action === '#') return; // native submit if no Formspree URL

    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    }
  });
</script>
