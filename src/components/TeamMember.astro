---
export interface Props {
  name: string;
  role: string;
  bio: string;
  albo?: string;
  photo?: string | null;
}

const { name, role, bio, albo, photo } = Astro.props;
---

<article class="flex flex-col items-center text-center">
  <!-- Photo placeholder -->
  <div
    class="w-32 h-32 rounded-full mb-5 overflow-hidden flex items-center justify-center shrink-0"
    style="background-color: #D1D5DB;"
    aria-label="Foto profilo placeholder"
  >
    {
      photo ? (
        <img
          src={photo}
          alt={`Foto di ${name}`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <svg
          class="w-16 h-16 opacity-40"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      )
    }
  </div>

  <!-- Name -->
  <h3
    class="text-xl font-semibold mb-1"
    style="font-family: var(--font-heading); color: var(--color-primary);"
  >
    {name}
  </h3>

  <!-- Role -->
  <p class="text-sm font-medium mb-3" style="color: var(--color-accent);">
    {role}
  </p>

  <!-- Divider -->
  <div class="section-divider mx-auto"></div>

  <!-- Bio -->
  <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
    {bio}
  </p>

  <!-- Albo -->
  {
    albo && (
      <p class="mt-4 text-xs italic opacity-60" style="color: var(--color-muted);">
        {albo}
      </p>
    )
  }
</article>
