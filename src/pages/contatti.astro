---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { it } from '../content/it';

const { info } = it.contatti;
---

<BaseLayout
  title={it.contatti.meta.title}
  description={it.contatti.meta.description}
>
  <!-- Page header -->
  <section
    class="py-20 lg:py-28"
    style="background-color: var(--color-primary);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p
        class="text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-accent);"
      >
        Siamo a Tua Disposizione
      </p>
      <h1
        class="text-4xl sm:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-heading);"
      >
        {it.contatti.title}
      </h1>
      <p class="text-lg opacity-75 text-white max-w-xl">
        {it.contatti.subtitle}
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-14">

        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="section-title">{it.contatti.form.title}</h2>
          <div class="section-divider"></div>
          <ContactForm />
        </div>

        <!-- Info sidebar -->
        <aside class="lg:col-span-2 space-y-8">
          <!-- Address -->
          <div>
            <h3
              class="text-xs font-semibold tracking-widest uppercase mb-3"
              style="color: var(--color-accent);"
            >
              {info.addressTitle}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
              {it.studio.address}
            </p>
          </div>

          <!-- Phone -->
          <div>
            <h3
              class="text-xs font-semibold tracking-widest uppercase mb-3"
              style="color: var(--color-accent);"
            >
              {info.phoneTitle}
            </h3>
            <a
              href="tel:091303025"
              class="block text-sm font-medium hover:opacity-70 transition-opacity"
              style="color: var(--color-primary);"
            >
              091 303025
            </a>
            <a
              href="tel:091220679"
              class="block text-sm mt-1 hover:opacity-70 transition-opacity"
              style="color: var(--color-muted);"
            >
              091 220679
            </a>
            <!-- Click-to-call CTA -->
            <a
              href="tel:091303025"
              class="btn-primary mt-4 inline-flex items-center gap-2 text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Chiama ora
            </a>
          </div>

          <!-- Email -->
          <div>
            <h3
              class="text-xs font-semibold tracking-widest uppercase mb-3"
              style="color: var(--color-accent);"
            >
              {info.emailTitle}
            </h3>
            <a
              href={`mailto:${it.studio.email}`}
              class="text-sm hover:opacity-70 transition-opacity"
              style="color: var(--color-primary);"
            >
              {it.studio.email}
            </a>
          </div>

          <!-- Hours -->
          <div>
            <h3
              class="text-xs font-semibold tracking-widest uppercase mb-3"
              style="color: var(--color-accent);"
            >
              {info.hoursTitle}
            </h3>
            <p class="text-sm whitespace-pre-line" style="color: var(--color-muted);">
              {info.hours}
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Mappa -->
  <section class="bg-white pb-20 lg:pb-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!--
        TODO: Sostituire con le coordinate reali dello studio.
        Per ottenere l'embed corretto:
        1. Vai su Google Maps e cerca l'indirizzo
        2. Clicca "Condividi" → "Incorpora una mappa"
        3. Copia il codice <iframe> e sostituisci quello qui sotto
      -->
      <div class="relative group overflow-hidden border border-gray-100" style="height: 400px;">
        <div class="absolute inset-0 bg-gray-300/50 pointer-events-none transition-opacity duration-300 group-hover:opacity-0 z-10"></div>
        <iframe
          title="Mappa Studio A.C.A.I."
          width="100%"
          height="100%"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3122.4!2d13.361267!3d38.115688!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zVmlhbGUgVmlsbGEgSGVsb2lzZSAyMSwgUGFsZXJtbw!5e0!3m2!1sit!2sit!4v1234567890"
          style="border:0;"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
