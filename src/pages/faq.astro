---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqItem from '../components/FaqItem.astro';
import { it } from '../content/it';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: it.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={it.faq.meta.title}
  description={it.faq.meta.description}
>
  <!-- FAQ JSON-LD (schema specifico della pagina) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />

  <!-- Page header -->
  <section
    class="py-20 lg:py-28"
    style="background-color: var(--color-primary);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p
        class="text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-accent);"
      >
        Risposte Rapide
      </p>
      <h1
        class="text-4xl sm:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-heading);"
      >
        {it.faq.title}
      </h1>
      <p class="text-lg opacity-75 text-white max-w-xl">
        {it.faq.subtitle}
      </p>
    </div>
  </section>

  <!-- FAQ accordion -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="divide-y divide-gray-100 border border-gray-100 bg-white p-6 sm:p-10">
        {
          it.faq.items.map((item, i) => (
            <FaqItem
              question={item.question}
              answer={item.answer}
              index={i}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-24" style="background-color: var(--color-bg-alt);">
    <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center">
      <h2
        class="text-3xl font-bold mb-4"
        style="font-family: var(--font-heading); color: var(--color-primary);"
      >
        Non hai trovato la risposta che cercavi?
      </h2>
      <p class="text-base mb-8 max-w-xl mx-auto" style="color: var(--color-muted);">
        Contattaci direttamente. Saremo lieti di rispondere a qualsiasi domanda in
        materia fiscale, tributaria o contabile.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contatti" class="btn-primary text-sm">
          Scrivici
        </a>
        <a
          href={`tel:${it.studio.phone.replace(/\s/g, '')}`}
          class="btn-outline text-sm"
        >
          Chiamaci
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
