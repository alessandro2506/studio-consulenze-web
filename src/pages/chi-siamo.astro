---
import BaseLayout from '../layouts/BaseLayout.astro';
import { it } from '../content/it';

const { storia, valori, approccio } = it.chiSiamo;
---

<BaseLayout
  title={it.chiSiamo.meta.title}
  description={it.chiSiamo.meta.description}
>
  <!-- Page header -->
  <section
    class="py-20 lg:py-28"
    style="background-color: var(--color-primary);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p
        class="text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-accent);"
      >
        Lo Studio
      </p>
      <h1
        class="text-4xl sm:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-heading);"
      >
        {it.chiSiamo.title}
      </h1>
      <p class="text-lg opacity-75 text-white max-w-xl">
        {it.chiSiamo.subtitle}
      </p>
    </div>
  </section>

  <!-- Storia -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <p
            class="text-xs font-semibold tracking-widest uppercase mb-3"
            style="color: var(--color-accent);"
          >
            La Nostra Identità
          </p>
          <h2 class="section-title">{storia.title}</h2>
          <div class="section-divider"></div>
          <div class="space-y-4">
            {
              storia.paragraphs.map((p) => (
                <p class="text-base leading-relaxed" style="color: var(--color-muted);">
                  {p
                    .replace('TODO:foundedYear', it.studio.foundedYear)
                    .replace('TODO:', it.studio.foundedYear)}
                </p>
              ))
            }
          </div>
        </div>

        <!-- Sidebar stats -->
        <div
          class="p-10 space-y-8"
          style="background-color: var(--color-bg-alt);"
        >
          <div class="border-l-4 pl-6" style="border-color: var(--color-accent);">
            <p
              class="text-4xl font-bold mb-1"
              style="font-family: var(--font-heading); color: var(--color-primary);"
            >
              {it.studio.foundedYear}
            </p>
            <p class="text-sm" style="color: var(--color-muted);">Anno di fondazione</p>
          </div>
          <div class="border-l-4 pl-6" style="border-color: var(--color-accent);">
            <p
              class="text-4xl font-bold mb-1"
              style="font-family: var(--font-heading); color: var(--color-primary);"
            >
              Palermo
            </p>
            <p class="text-sm" style="color: var(--color-muted);">
              {it.studio.address}
            </p>
          </div>
          <div class="border-l-4 pl-6" style="border-color: var(--color-accent);">
            <p
              class="text-4xl font-bold mb-1"
              style="font-family: var(--font-heading); color: var(--color-primary);"
            >
              6
            </p>
            <p class="text-sm" style="color: var(--color-muted);">
              Aree di specializzazione
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Valori -->
  <section class="py-20 lg:py-28" style="background-color: var(--color-bg-alt);">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
        <p
          class="text-xs font-semibold tracking-widest uppercase mb-3"
          style="color: var(--color-accent);"
        >
          Cosa Ci Guida
        </p>
        <h2 class="section-title">{valori.title}</h2>
        <div class="section-divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          valori.items.map((v, i) => (
            <div class="card p-8">
              <div
                class="text-xs font-bold tracking-widest uppercase mb-3"
                style="color: var(--color-accent);"
              >
                0{i + 1}
              </div>
              <h3
                class="text-xl font-semibold mb-3"
                style="font-family: var(--font-heading); color: var(--color-primary);"
              >
                {v.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
                {v.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Approccio -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p
          class="text-xs font-semibold tracking-widest uppercase mb-3"
          style="color: var(--color-accent);"
        >
          Il Metodo
        </p>
        <h2 class="section-title">{approccio.title}</h2>
        <div class="section-divider mx-auto"></div>
        <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
          {approccio.description}
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/servizi" class="btn-primary text-sm">
            I Nostri Servizi
          </a>
          <a href="/contatti" class="btn-outline text-sm">
            Contattaci
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
